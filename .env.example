# ── AI Provider ──────────────────────────────────────────────────
# Get free key at console.groq.com (no credit card needed)
GROQ_API_KEY=your_groq_api_key_here

# ── GitHub ────────────────────────────────────────────────────────
# github.com/settings/tokens → New token → scopes: repo, issues, pull_requests
GITHUB_TOKEN=your_github_pat_here

# ── Jira (optional — defect tickets) ─────────────────────────────
# id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token_here

# ── Slack (optional — QA alerts) ─────────────────────────────────
# api.slack.com/apps → Create App → Bot Token Scopes: chat:write, channels:read
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_TEAM_ID=your_slack_team_id

# ── Database ──────────────────────────────────────────────────────
POSTGRES_DB=testmind
POSTGRES_USER=testmind
POSTGRES_PASSWORD=change_this_strong_password

# ── Backend ───────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=generate_a_64_char_random_hex_string_here
AI_ENGINE_URL=http://ai-engine:8001
DATABASE_URL=jdbc:postgresql://postgres:5432/testmind

# ── Frontend ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
